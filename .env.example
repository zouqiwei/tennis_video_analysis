# Local development defaults.
#
# The application does not currently require environment variables.
# Keep this file as a copyable starting point for future local settings:
#
# cp .env.example .env

# FastAPI import path used by uvicorn.
APP_MODULE=app.main:app

# Default local development server.
HOST=127.0.0.1
PORT=8000

# Runtime data directories used by app/main.py.
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/outputs
